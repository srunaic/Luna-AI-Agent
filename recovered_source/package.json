{
  "name": "luna-ai-agent",
  "displayName": "Luna AI Agent",
  "description": "Luna AI Agent - High-performance AI Orchestrator",
  "version": "0.1.39",
  "repository": {
    "type": "git",
    "url": "https://github.com/srunaic/Luna-AI-Agent.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "electron/main.js",
  "contributes": {
    "commands": [
      {
        "command": "luna.openChat",
        "title": "Open Luna Chat"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "luna.openChat",
          "when": "editorTextFocus",
          "group": "navigation"
        }
      ]
    }
  },
  "homepage": "./",
  "dependencies": {
    "electron-log": "^5.4.2",
    "electron-updater": "^6.6.2"
  }
}